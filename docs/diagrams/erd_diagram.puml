@startchen

title ERD: Platform Kursus Online

' ==============================
' ENTITAS
' ==============================

entity PENGGUNA {
    id <<key>>
    email
    nama_lengkap
    peran
    status
}

entity KURSUS {
    id <<key>>
    judul
    harga
    gratis
    status
}

entity KATEGORI {
    id <<key>>
    nama
    slug
}

entity LEVEL {
    id <<key>>
    nama
}

entity BAB {
    id <<key>>
    judul
    urutan
}

entity KONTEN {
    id <<key>>
    judul
    tipe_konten
    wajib
}

entity SOAL_KUIS {
    id <<key>>
    pertanyaan
    jawaban_benar
}

' ==============================
' RELASI: PENGGUNA <-> KURSUS (M:N)
' Diletakkan pertama supaya Graphviz
' menempatkan PENGGUNA & KURSUS
' di posisi berseberangan
' ==============================

relationship MENDAFTAR {
    tgl_daftar
    progres
}
MENDAFTAR -N- PENGGUNA
MENDAFTAR -N- KURSUS

relationship MEMBERI_ULASAN {
    nilai
    komentar
    status
}
MEMBERI_ULASAN -N- PENGGUNA
MEMBERI_ULASAN -N- KURSUS

relationship MENDAPAT_SERTIFIKAT {
    kode
    tgl_terbit
}
MENDAPAT_SERTIFIKAT -N- PENGGUNA
MENDAPAT_SERTIFIKAT -N- KURSUS

' ==============================
' RELASI: PENGGUNA -> KURSUS (1:N mengajar)
' ==============================

relationship MENGAJAR {
}
MENGAJAR -1- PENGGUNA
MENGAJAR -N- KURSUS

' ==============================
' RELASI: Klasifikasi KURSUS
' Diletakkan setelah group PENGGUNA
' supaya KATEGORI & LEVEL menempel
' di sisi KURSUS yang berbeda
' ==============================

relationship DIKATEGORIKAN {
}
DIKATEGORIKAN -1- KATEGORI
DIKATEGORIKAN -N- KURSUS

relationship BERLEVEL {
}
BERLEVEL -1- LEVEL
BERLEVEL -N- KURSUS

' ==============================
' RELASI: Chain konten KURSUS
' Dideklarasikan berurutan supaya
' Graphviz membentuk garis lurus
' ke samping / bawah
' ==============================

relationship MEMILIKI_BAB {
}
MEMILIKI_BAB -1- KURSUS
MEMILIKI_BAB -N- BAB

relationship MEMILIKI_KONTEN {
}
MEMILIKI_KONTEN -1- BAB
MEMILIKI_KONTEN -N- KONTEN

relationship MEMILIKI_SOAL {
}
MEMILIKI_SOAL -1- KONTEN
MEMILIKI_SOAL -N- SOAL_KUIS

@endchen
