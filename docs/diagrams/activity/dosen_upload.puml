@startuml
title Aktivitas: Dosen Mengunggah Kelas

skinparam backgroundColor #FEFEFE
skinparam ActivityBorderColor #9E9E9E
skinparam ArrowColor #555555

|Dosen|
start
:Login sebagai
Dosen; <<#E3F2FD>>
:Buka menu
Dashboard Dosen; <<#E3F2FD>>
:Klik Unggah
Kelas Baru; <<#E3F2FD>>
:Isi detail kelas
(Judul, Deskripsi,
Kategori, Harga); <<#E3F2FD>>
:Buat bab
pembelajaran; <<#E3F2FD>>

repeat
    :Tambahkan materi
ke dalam bab; <<#E3F2FD>>
    :Pilih tipe materi
(Video/PDF/Kuis); <<#E3F2FD>>
    if (Apakah Kuis?) then (Ya)
        :Buat pertanyaan
dan pilihan
ganda; <<#E3F2FD>>
        :Tentukan jawaban
yang benar; <<#E3F2FD>>
    else (File/Tautan)
        :Unggah file atau
masukkan URL; <<#E3F2FD>>
    endif
repeat while (Ada materi lain?)

:Tinjau ulang
struktur kelas; <<#E3F2FD>>
:Publikasikan kelas; <<#E3F2FD>>

|Sistem|
:Simpan data kelas
ke database; <<#FFFFFF>>
:Tampilkan kelas
di katalog publik; <<#FFFFFF>>

stop
@enduml


